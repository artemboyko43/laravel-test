{
    "name": "upwork-test/laravel-app",
    "description": "Laravel backend tasks",
    "type": "project",
    "authors": [
        {
            "name": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.53"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
